const express = require('express');
const { Pool } = require('pg');

const app = express();
app.use(express.json());
// OS CONST SÃO DECLARAÇOES 
const pool = new Pool({ connectionString: process.env.DATABASE_URL });

async function init() {
  await pool.query(`
    CREATE TABLE IF NOT EXISTS tarefas (
      id SERIAL PRIMARY KEY,
      titulo TEXT NOT NULL,
      feita BOOLEAN DEFAULT false
    )
  `);
}

app.get('/tarefas', async (req, res) => {
  const { rows } = await pool.query('SELECT * FROM tarefas ORDER BY id');
  res.json(rows);
});

app.post('/tarefas', async (req, res) => {
  const { titulo } = req.body;
  const { rows } = await pool.query(
    'INSERT INTO tarefas (titulo) VALUES ($1) RETURNING *',
    [titulo]
  );
  res.status(201).json(rows[0]);
});

app.delete('/tarefas/:id', async (req, res) => {
  await pool.query('DELETE FROM tarefas WHERE id=$1', [req.params.id]);
  res.json({ mensagem: 'Tarefa deletada' });
});

init().then(() => app.listen(3000, () => console.log('API rodando na porta 3000')));
